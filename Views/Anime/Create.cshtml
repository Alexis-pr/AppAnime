@model AppAnime.Models.Anime

@{
    ViewData["Title"] = "Crear Anime";
}

<h2>Crear Anime</h2>

<form asp-action="Create">

    <div class="form-group">
        <label>Titulo</label>
        <input asp-for="Titulo" class="form-control"/>
    </div>

    <div class="form-group">
        <label>Genero</label>
        <input asp-for="Genero" class="form-control"/>
    </div>

    <div class="form-group">
        <label>Episodios</label>
        <input asp-for="Episodios" class="form-control"/>
    </div>

    <div class="form-group">
        <label>Sinopsis</label>
        <textarea asp-for="Sinopsis" class="form-control"></textarea>
    </div>
    
    <div class="input-field">
        <input asp-for="Imagen" />
        <label>URL Imagen</label>
    </div>

    <div class="form-group">
        <label>Estado</label>
        <select asp-for="Estado" class="form-control">
            <option value="En emisión">En emisión</option>
            <option value="Finalizado">Finalizado</option>
            <option value="Pausado">Pausado</option>
        </select>
    </div>

    <br />

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>

</form>