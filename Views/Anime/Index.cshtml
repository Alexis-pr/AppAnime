@model IEnumerable<AppAnime.Models.Anime>

<h3>🎌 Cartelera Anime</h3>

<a asp-action="Create" class="btn purple">
    Nuevo Anime
</a>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col s12 m6 l4">

            <div class="card">

                <div class="card-image">
                    <img src="@(item.Imagen ?? "https://via.placeholder.com/300x400")" 
                         style="height:300px; width:100%; object-fit:cover;">

                    <span class="card-title black-text">
                        @item.Titulo
                    </span>
                </div>

                <div class="card-content">

                    <p><strong>Genero:</strong> @item.Genero</p>
                    <p><strong>Episodios:</strong> @item.Episodios</p>
                    <p><strong>Estado:</strong> @item.Estado</p>

                </div>

                <div class="card-action">

                    <a asp-action="Details" asp-route-id="@item.Id">
                        Ver
                    </a>

                    <a asp-action="Edit" asp-route-id="@item.Id">
                        Editar
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id">
                        Eliminar
                    </a>

                </div>

            </div>

        </div>
    }

</div>